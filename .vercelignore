# Development files
.env.local
.env.development
.env.test
.env

# Testing
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Scripts
scripts/

# Documentation
*.md
!README.md

# IDE
.vscode/
.idea/

# Build cache (will be rebuilt)
.next/cache
.next/trace

# Node modules (already ignored by default)
node_modules/

# Prisma (keep only schema)
prisma/migrations/

# Large public assets
public/projects/videos/*.mp4
public/projects/videos/*.webm
public/files/tests/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
