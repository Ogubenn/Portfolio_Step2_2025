# Development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__/
**/test/
coverage/

# Scripts (not needed in production)
scripts/

# Documentation (except README)
*.md
!README.md
VERCEL_DEPLOY_DEBUG.md
TODO.md
ROADMAP.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build cache (rebuilt on deploy)
.next/cache/
.next/trace

# Prisma (migrations not needed, only schema)
prisma/migrations/

# Large public assets (use Cloudinary instead)
public/projects/videos/*.mp4
public/projects/videos/*.webm
public/files/tests/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.tmp

# Git files (already ignored by Vercel)
.git/
.gitignore
.gitattributes
